{
  "app": "npx ts-node --prefer-ts-exts bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "yarn.lock",
      "node_modules",
      "test",
      "dist"
    ]
  },
  "context": {
    "approvedRegions": ["eu-west-1", "eu-west-3", "eu-central-1", "us-east-1"],
    "allowedRdsClasses": [ ],
    "allowedEc2Types": ["t4g.nano", "t4g.micro"],
    "bedrockAllowedPrincipals": [],
    "watchdogScheduleHour": 18
  }
}
